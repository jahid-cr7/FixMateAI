# Phase 5 is disabled by default. Copy values into your shell environment;
# FixMate AI does not automatically load this file.
FIXMATE_LLM_PROVIDER=disabled
FIXMATE_LLM_TIMEOUT_SECONDS=15

# Optional HTTPS cloud chat-completions provider.
# Never place a real key in this example file or commit a populated .env file.
FIXMATE_CLOUD_API_URL=https://provider.example/v1/chat/completions
FIXMATE_CLOUD_MODEL=replace-with-provider-model-name
FIXMATE_CLOUD_API_KEY=

# Optional loopback-only Ollama-compatible provider.
FIXMATE_OLLAMA_URL=http://127.0.0.1:11434/api/chat
FIXMATE_OLLAMA_MODEL=

# Phase 6 local API. Generate your own high-entropy token and set it only in
# your shell or private .env file. POST routes stay unavailable when empty.
FIXMATE_API_TOKEN=
# Keep 127.0.0.1 for native development. Compose overrides this to 0.0.0.0
# only inside the API container and publishes the port on host loopback.
FIXMATE_API_HOST=127.0.0.1
FIXMATE_API_PORT=8000
FIXMATE_API_CORS_ORIGINS=http://127.0.0.1:8501,http://localhost:8501
FIXMATE_API_MAX_REQUEST_BYTES=65536
FIXMATE_API_DIAGNOSTIC_RATE_LIMIT=5
FIXMATE_API_ASSISTANT_RATE_LIMIT=20
FIXMATE_API_REPORT_RATE_LIMIT=10
FIXMATE_API_RATE_WINDOW_SECONDS=60
# Optional database override; blank uses data/fixmate.db.
FIXMATE_DATABASE_PATH=
